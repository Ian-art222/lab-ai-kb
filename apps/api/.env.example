APP_NAME=Lab AI KB API
APP_ENV=dev

# PostgreSQL connection used by FastAPI and Alembic
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/lab_ai_kb

# Auth
JWT_SECRET_KEY=please-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File storage root, relative to apps/api by default
UPLOAD_DIR=uploads

# Optional provider/env fallback values.
# Main runtime chat / retrieval provider settings should be maintained in the system settings UI.
# Recommended pre-release defaults:
#   chat                = gemini / gemini-2.5-flash
#   retrieval embedding = qwen / text-embedding-v4
LLM_PROVIDER=gemini
LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_API_VERSION=
LLM_TIMEOUT=60

EMBEDDING_PROVIDER=qwen
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_VERSION=
EMBEDDING_TIMEOUT=60

# Retrieval embedding batch fallback:
# 1) system setting embedding_batch_size
# 2) EMBED_BATCH_SIZE
# 3) code default
# For Qwen / DashScope, keep this at 10 unless the system setting overrides it with a compatible value.
EMBED_BATCH_SIZE=10
EMBED_RETRY_TIMES=2
EMBED_RETRY_BASE_DELAY=1.0
EMBED_BATCH_DELAY=0.25

# QA retrieval / ranking
QA_RETRIEVAL_MODE=hybrid
QA_SEMANTIC_THRESHOLD=0.25
QA_LEXICAL_THRESHOLD=0.012
QA_HYBRID_THRESHOLD=0.012
QA_PGVECTOR_RETRIEVAL_ENABLED=true
QA_PGVECTOR_SEMANTIC_ENABLED=true
QA_PGVECTOR_PROBE_LIMIT=256
QA_RERANK_ENABLED=true
QA_RERANK_TOP_N=20
QA_RERANK_LATENCY_BUDGET_MS=1200
QA_MAX_CHUNKS_PER_DOC=2
QA_TARGET_DISTINCT_DOCS=3
QA_MIN_DISTINCT_DOCS_FOR_MULTI_SOURCE=2
QA_SINGLE_DOC_DOMINANCE_RATIO=1.6
QA_DIVERSITY_RERANK_ENABLED=false
QA_DIVERSITY_LAMBDA=0.75
QA_DIVERSITY_FETCH_K=24
QA_REDUNDANCY_SIM_THRESHOLD=0.9
QA_REDUNDANCY_ADJACENT_WINDOW=1
QA_QUERY_EXPANSION_ENABLED=false
QA_QUERY_EXPANSION_MAX_QUERIES=3
QA_STRICT_MIN_CITATIONS=1

QA_FAILURE_CASES_DIR=evals/fixtures/failure_cases
